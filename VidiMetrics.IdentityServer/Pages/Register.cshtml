@page "/register"
@model VidiMetrics.IdentityServer.Pages.RegisterModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Register";
}

<div class="w-full max-w-lg">
    <div class="text-center mb-8">
        <a class="inline-block mb-6" href="/">
            <span class="text-3xl font-headline font-bold text-gradient-primary tracking-tight">VidiMetrics.Ai</span>
        </a>
        <h1 class="text-4xl font-headline font-bold text-on-surface tracking-tighter mb-3">Sync with the Stream</h1>
        <p class="text-on-surface-variant font-label text-sm uppercase tracking-[0.2em]">Register your observer terminal</p>
    </div>

    @if (Model.IsUrlInvalid)
    {
        <div class="glass-panel border-error/20 bg-error-container/10 rounded-xl p-6 mb-8 text-center animate-in fade-in slide-in-from-top-4 duration-500">
            <span class="material-symbols-outlined text-error text-3xl mb-3">report</span>
            <h3 class="text-on-surface font-headline font-bold text-lg mb-1">Well, that didn't go as planned</h3>
            <p class="text-on-surface-variant text-xs font-body leading-relaxed max-w-xs mx-auto">
                We're experiencing technical difficulties. Please stand by or try again later.
            </p>
        </div>
    }

    @if (!Model.IsUrlInvalid)
    {
        <div class="glass-panel ghost-border rounded-xl p-8 md:p-10 shadow-[0_32px_64px_-12px_rgba(0,0,0,0.6)]">
            <form method="post" asp-route-returnUrl="@Model.ReturnUrl" class="space-y-6">
                
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="text-error text-sm font-body bg-error-container/20 border border-error/20 rounded-lg px-4 py-3">
                        <div asp-validation-summary="All" class="list-none"></div>
                    </div>
                }

                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="block text-[10px] font-label uppercase tracking-widest text-secondary font-semibold ml-1" asp-for="Input.FirstName">First Designation</label>
                        <input 
                            asp-for="Input.FirstName"
                            class="block w-full bg-surface-container-lowest/50 border-0 focus:ring-2 focus:ring-secondary/20 text-on-surface rounded-lg py-3 px-4 transition-all duration-300 placeholder:text-on-surface-variant/30 font-body text-sm" 
                            placeholder="John" />
                    </div>
                    <div class="space-y-2">
                        <label class="block text-[10px] font-label uppercase tracking-widest text-secondary font-semibold ml-1" asp-for="Input.LastName">Last Designation</label>
                        <input 
                            asp-for="Input.LastName"
                            class="block w-full bg-surface-container-lowest/50 border-0 focus:ring-2 focus:ring-secondary/20 text-on-surface rounded-lg py-3 px-4 transition-all duration-300 placeholder:text-on-surface-variant/30 font-body text-sm" 
                            placeholder="Doe" />
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="block text-[10px] font-label uppercase tracking-widest text-secondary font-semibold ml-1" asp-for="Input.Email">Synchronization Email</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <span class="material-symbols-outlined text-on-surface-variant text-lg">alternate_email</span>
                        </div>
                        <input 
                            asp-for="Input.Email"
                            class="block w-full bg-surface-container-lowest/50 border-0 focus:ring-2 focus:ring-secondary/20 text-on-surface rounded-lg py-4 pl-12 transition-all duration-300 placeholder:text-on-surface-variant/30 font-body text-sm" 
                            placeholder="observer@vidimetrics.ai" 
                            type="email" />
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="space-y-2">
                        <label class="block text-[10px] font-label uppercase tracking-widest text-secondary font-semibold ml-1" asp-for="Input.Password">Encryption Key</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                <span class="material-symbols-outlined text-on-surface-variant text-lg">lock</span>
                            </div>
                            <input 
                                asp-for="Input.Password"
                                class="block w-full bg-surface-container-lowest/50 border-0 focus:ring-2 focus:ring-secondary/20 text-on-surface rounded-lg py-4 pl-12 transition-all duration-300 placeholder:text-on-surface-variant/30 font-body text-sm" 
                                placeholder="••••••••" 
                                type="password" />
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label class="block text-[10px] font-label uppercase tracking-widest text-secondary font-semibold ml-1" asp-for="Input.ConfirmPassword">Verify Key</label>
                        <input 
                            asp-for="Input.ConfirmPassword"
                            class="block w-full bg-surface-container-lowest/50 border-0 focus:ring-2 focus:ring-secondary/20 text-on-surface rounded-lg py-4 px-4 transition-all duration-300 placeholder:text-on-surface-variant/30 font-body text-sm" 
                            placeholder="••••••••" 
                            type="password" />
                    </div>
                </div>

                <button class="w-full relative overflow-hidden group btn-gradient font-headline font-bold py-4 rounded-lg flex items-center justify-center gap-3 active:scale-[0.98] transition-all shadow-[0_8px_24px_-4px_rgba(120,24,198,0.4)] mt-4" type="submit">
                    <span class="text-sm tracking-widest uppercase">Initialize Account</span>
                    <span class="material-symbols-outlined text-lg group-hover:translate-x-1 transition-transform">sync_alt</span>
                </button>
            </form>

            <div class="mt-8 text-center">
                <p class="text-on-surface-variant text-sm font-body">
                    Already synchronized? 
                    <a class="text-secondary font-semibold hover:text-primary transition-colors underline-offset-4 hover:underline" href="/login?ReturnUrl=@System.Net.WebUtility.UrlEncode(Model.ReturnUrl)">
                        Access Terminal
                    </a>
                </p>
            </div>
        </div>
    }
</div>
