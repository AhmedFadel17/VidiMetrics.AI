@page "/reset-password"
@model VidiMetrics.IdentityServer.Pages.ResetPasswordModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Reset Password";
}

<div class="w-full max-w-md">
    <div class="text-center mb-10">
        <a href="/" class="inline-block mb-8">
            <span class="text-3xl font-headline font-bold text-gradient-primary tracking-tight">VidiMetrics.Ai</span>
        </a>
        <div class="w-20 h-20 bg-surface-container-high rounded-3xl mx-auto flex items-center justify-center mb-8 ghost-border shadow-xl">
            <span class="material-symbols-outlined text-on-surface-variant text-4xl">lock_reset</span>
        </div>
        <h1 class="text-4xl font-headline font-bold text-on-surface tracking-tighter mb-4">Reset Sequence</h1>
        <p class="text-on-surface-variant text-sm font-label uppercase tracking-[0.2em]">Update Your Encryption Key</p>
    </div>

    <div class="glass-panel ghost-border rounded-xl p-8 shadow-2xl">
        <form method="post" class="space-y-6">
            <input asp-for="Input.Code" type="hidden" />
            <input asp-for="Input.Email" type="hidden" />
            
            <div class="space-y-2">
                <label class="block text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant ml-1 font-bold">New Encryption Key</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <span class="material-symbols-outlined text-on-surface-variant text-lg">lock</span>
                    </div>
                    <input 
                        asp-for="Input.Password"
                        class="block w-full bg-surface-container-lowest/50 border-0 focus:ring-2 focus:ring-secondary/20 text-on-surface rounded-lg py-4 pl-12 transition-all duration-300 placeholder:text-on-surface-variant/30 font-body text-sm" 
                        placeholder="••••••••••••" 
                        type="password"
                    />
                </div>
                <span asp-validation-for="Input.Password" class="text-error text-xs"></span>
            </div>

            <div class="space-y-2">
                <label class="block text-[10px] font-label uppercase tracking-[0.2em] text-on-surface-variant ml-1 font-bold">Confirm Key</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <span class="material-symbols-outlined text-on-surface-variant text-lg">lock</span>
                    </div>
                    <input 
                        asp-for="Input.ConfirmPassword"
                        class="block w-full bg-surface-container-lowest/50 border-0 focus:ring-2 focus:ring-secondary/20 text-on-surface rounded-lg py-4 pl-12 transition-all duration-300 placeholder:text-on-surface-variant/30 font-body text-sm" 
                        placeholder="••••••••••••" 
                        type="password"
                    />
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-error text-xs"></span>
            </div>
            
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="text-error text-sm font-body bg-error-container/20 border border-error/20 rounded-lg px-4 py-3">
                    <div asp-validation-summary="All" class="list-none"></div>
                </div>
            }

            <button class="w-full py-4 btn-gradient rounded-lg font-bold tracking-widest uppercase text-xs shadow-lg shadow-primary/20 active:scale-[0.98] transition-all mt-4" type="submit">
                Execute Reset Sequence
            </button>
        </form>
    </div>

    <div class="mt-8 text-center">
        <a class="text-on-surface-variant hover:text-primary transition-colors text-sm flex items-center justify-center gap-2 group" asp-page="./Login">
            <span class="material-symbols-outlined text-sm group-hover:-translate-x-1 transition-transform">arrow_back</span>
            Return to Login
        </a>
    </div>
</div>
